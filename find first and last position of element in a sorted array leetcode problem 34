// find first and last position of element in a sorted array leetcode problem 34 solution 

class Solution {
public:
    int findFirst(vector<int>& nums, int target) {
        int st = 0, end = nums.size() - 1;
        int firstOcc = -1;
        
        while (st <= end) {
            int mid = st + (end - st) / 2;
            if (nums[mid] == target) {
                firstOcc = mid;
                end = mid - 1;
            }
            else if (nums[mid] < target) {
                st = mid + 1;
            }
            else {
                end = mid - 1;
            }
        }
        return firstOcc;
    }
    
    int findLast(vector<int>& nums, int target) {
        int st = 0, end = nums.size() - 1;
        int lastOcc = -1;
        
        while (st <= end) {
            int mid = st + (end - st) / 2;
            if (nums[mid] == target) {
                lastOcc = mid;
                st = mid + 1;
            }
            else if (nums[mid] < target) {
                st = mid + 1;
            }
            else {
                end = mid - 1;
            }
        }
        return lastOcc;
    }
    
    vector<int> searchRange(vector<int>& nums, int target) {
        int first = findFirst(nums, target);
        int last = findLast(nums, target);
        return {first, last};
    }
};
