// solution to leetcode problem 875 koko eating banana

class Solution {
public:
    int hoursNeeded(vector<int>& piles, int k) {
        int hours = 0;
        for (int pile : piles) {
            hours += (pile + k - 1) / k;
        }
        return hours;
    }
    
    int minEatingSpeed(vector<int>& piles, int h) {
        int st = 1;
        int end = *max_element(piles.begin(), piles.end());
        
        while (st < end) {
            int mid = st + (end - st) / 2;
            
            if (hoursNeeded(piles, mid) <= h) {
                end = mid;
            } else {
                st = mid + 1;
            }
        }
        
        return st;
    }
};
