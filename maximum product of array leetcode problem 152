// maximum product of array leetcode problem 152 solution

class Solution {
public:
    int maxProduct(vector<int>& nums) {
        int maxProd = nums[0];
        int minProd = nums[0];
        int result = nums[0];

        for (int i = 1; i < nums.size(); i++) {
            int currMax = maxProd; // save old maxProd before overwriting

            maxProd = max({nums[i], maxProd * nums[i], minProd * nums[i]});
            minProd = min({nums[i], currMax * nums[i], minProd * nums[i]});

            result = max(result, maxProd);
        }

        return result;
    }
};
