// move zeros leetcode question 283 solution

class Solution {
public:
    void moveZeroes(vector<int>& nums) {
        int insertPos = 0;
        for (int i = 0; i < nums.size(); i++) {
            if (nums[i] != 0) {
                nums[insertPos] = nums[i];
                insertPos++;
            }
        }
        for (int j = insertPos; j < nums.size(); j++) {
            nums[j] = 0;
        }
    }
};
